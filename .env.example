# Database
DATABASE_URL=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://rfyglobal.org

# Admin Credentials (seed / env fallback)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Credentials encryption key (generate: openssl rand -hex 32)
CREDENTIALS_ENCRYPTION_KEY=

# Cloudinary (replaces Uploadthing)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App
NEXT_PUBLIC_APP_URL=https://rfyglobal.org

# Cron jobs (Bearer token for /api/cron/* endpoints)
CRON_SECRET=

# Brevo email (env fallback — runtime values can also be saved via Admin → Credentials)
BREVO_API_KEY=
BREVO_FROM_EMAIL=hello@rfyglobal.org
BREVO_FROM_NAME=Room For You

# Payment providers (env fallback — preferred path is Admin → Credentials, encrypted in DB)
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=
PAYAZA_SECRET_KEY=
PAYAZA_WEBHOOK_SECRET=

# Optional — Google Search Console HTML tag verification (see layout metadata)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
