# Database
DATABASE_URL=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://rfyglobal.org

# Admin Credentials (seed / env fallback)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Credentials encryption key (generate: openssl rand -hex 32)
